{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2021",
    "lib": ["ES2021"],

    "declaration": true,
    "sourceMap": true,
    "outDir": "./dist",
    "removeComments": true,

    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,

    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,

    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": false,

    "moduleResolution": "node",
    "baseUrl": "./",

    "incremental": true,
    "skipLibCheck": true
  }
}
